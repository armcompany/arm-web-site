{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/importing",
      "destination": "https://landpage-armimports.vercel.app/importing"
    },
    {
      "source": "/importing/:path*",
      "destination": "https://landpage-armimports.vercel.app/importing/:path*"
    }
  ]
}
